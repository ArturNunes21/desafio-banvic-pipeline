# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env
#
# O arquivo .env é ignorado pelo Git e não deve ser commitado.

DB_HOST=airflow-postgresql
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<sua_senha>
DB_DATABASE=postgres

# Chave Flask do Airflow Webserver (gere uma aleatória em produção)
WEBSERVER_SECRET_KEY=<gere_uma_chave_aleatoria>

# URI completa para a conexão postgres_default do Airflow
# Deve usar a mesma senha definida em DB_PASSWORD
AIRFLOW_CONN_POSTGRES_DEFAULT=postgresql://postgres:<sua_senha>@airflow-postgresql:5432/postgres
